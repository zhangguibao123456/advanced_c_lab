{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake configure",
      "type": "shell",
      "command": "cmake -S . -B build -G Ninja",
      "problemMatcher": []
    },
    {
      "label": "cmake build",
      "type": "shell",
      "command": "cmake --build build",
      "dependsOn": "cmake configure",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "ctest",
      "type": "shell",
      "command": "ctest --test-dir build --output-on-failure",
      "dependsOn": "cmake build",
      "group": "test",
      "problemMatcher": []
    }
  ]
}

